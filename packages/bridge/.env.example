# CC Pocket Bridge configuration example.
#
# Copy this file to a private path such as ~/.ccpocket/bridge.env, edit it,
# then load it with your shell, service manager, or container --env-file.
# Do not commit real deployment secrets.

# Local Bridge listener.
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# Optional local Bridge API key. The relay pairing secret is generated
# separately and printed in the terminal QR code.
# BRIDGE_API_KEY=

# Project directories the Bridge may access, comma-separated.
# BRIDGE_ALLOWED_DIRS=/home/user

# Public relay reachable by the phone. Leave unset to use the default public
# relay, or set it to override. Leave BRIDGE_RELAY_TOKEN unset for official-style
# open relays.
# BRIDGE_RELAY_URL=wss://nqqlcknhdxys.sealoshzh.site

# Set only when the relay server was started with RELAY_ADMIN_TOKEN.
# BRIDGE_RELAY_TOKEN=

# Optional stable room values. Leave unset for generated one-time values.
# BRIDGE_RELAY_ROOM_ID=
# BRIDGE_RELAY_ROOM_SECRET=

# Optional: disable LAN mDNS discovery when relay-only pairing is preferred.
# BRIDGE_DISABLE_MDNS=1
