# CC Pocket Relay configuration example.
#
# Copy this file to a private location such as /etc/ccpocket/relay.env, edit
# RELAY_PUBLIC_URL, then load it with your process manager, shell, or Docker
# --env-file. Do not commit real deployment secrets.

# Bind address and local port inside the server/container.
RELAY_HOST=0.0.0.0
RELAY_PORT=8787

# Public URL that phones can reach. Use wss:// in production.
RELAY_PUBLIC_URL=wss://relay.example.com

# Leave unset for official-style open registration.
# Set a value only for trusted self-hosted mode.
# RELAY_ADMIN_TOKEN=

# Conservative defaults suitable for a small server.
RELAY_MAX_ROOMS=500
RELAY_MAX_CONNECTIONS=1200
RELAY_MAX_ROOMS_PER_IP=5
RELAY_MAX_CONNECTIONS_PER_IP=20
RELAY_MAX_MESSAGE_BYTES=1048576
RELAY_IDLE_ROOM_TTL_MS=1800000
RELAY_HEARTBEAT_INTERVAL_MS=30000
RELAY_ABUSE_WINDOW_MS=60000
RELAY_MAX_REJECTIONS_PER_IP=30
